# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# OpenRouter (provided by Alex Morrison)
OPENROUTER_API_KEY=your_openrouter_api_key

# Admin auth (simple password protection for Phase 1)
ADMIN_PASSWORD=choose_a_strong_password

# Cron security
CRON_SECRET=choose_a_random_string

# App URL (used for internal references)
NEXT_PUBLIC_APP_URL=https://your-vercel-app.vercel.app

# n8n delivery pipeline
# Webhook URL from the "EFH — Deliver Feedback PDF" workflow.
# Use /webhook-test/ while the workflow is in test mode; swap to /webhook/ once activated.
N8N_WEBHOOK_URL=https://expertfundraising17.app.n8n.cloud/webhook/efh-delivery
# Shared secret — must match the Value field in n8n's "EFH Webhook Secret" Header Auth credential
N8N_CALLBACK_SECRET=choose_a_random_string
